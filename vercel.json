{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": "{api/oauth.ts,index.html,node_modules/**}"
    },
    "api/interactions.ts": {
      "maxDuration": 60,
      "includeFiles": "{src/**,node_modules/**}"
    },
    "api/discord-oauth-callback.ts": {
      "maxDuration": 10,
      "includeFiles": "{api/oauth.ts,src/utils/**,public/pages/**,node_modules/**}"
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install"
}
